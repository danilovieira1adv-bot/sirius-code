def _arg_for_display(args):
    if isinstance(args, dict):
        for key in ('command', 'filename', 'file_path', 'path', 'query', 'task'):
            if key in args:
                return str(args[key])[:120]
        return str(args)[:120]
    return str(args)[:120] if args else ''


def _print_diff_lines(content, prefix, color, max_lines=6):
    lines = str(content).split('\n')
    shown = lines[:max_lines]
    for ln in shown:
        print(f"  {color}{prefix}{RESET} {WHITE}{ln[:160]}{RESET}")
    if len(lines) > max_lines:
        print(f"  {GRAY}{SYM_RESULT}  … +{len(lines) - max_lines} linhas{RESET}")


def print_tool_call(name, args):
    display = TOOL_DISPLAY.get(name, name)

    if name == 'write_file' and isinstance(args, dict):
        path = args.get('filename') or args.get('file_path') or args.get('path', '')
        print(f"  {ORANGE}{SYM_DIAMOND} {BOLD}{display}{RESET}{GRAY}({path}){RESET}")
        content = args.get('content', '')
        if content:
            _print_diff_lines(content, SYM_PLUS, GREEN, max_lines=6)
        return

    if name == 'edit_file' and isinstance(args, dict):
        path = args.get('filename') or args.get('file_path') or args.get('path', '')
        print(f"  {ORANGE}{SYM_DIAMOND} {BOLD}{display}{RESET}{GRAY}({path}){RESET}")
        old = args.get('old_str') or args.get('old') or ''
        new = args.get('new_str') or args.get('new') or args.get('content') or ''
        if old:
            _print_diff_lines(old, SYM_MINUS, RED, max_lines=4)
        if new:
            _print_diff_lines(new, SYM_PLUS, GREEN, max_lines=4)
        return

    print(f"  {ORANGE}{SYM_DIAMOND} {BOLD}{display}{RESET}{GRAY}({_arg_for_display(args)}){RESET}")


def print_tool_result(result, max_lines=10):
    lines = str(result).splitlines()
    shown = lines[:max_lines]
    for line in shown:
        print(f"  {GRAY}{SYM_RESULT}  {WHITE}{line}{RESET}")
    if len(lines) > max_lines:
        print(f"  {GRAY}{SYM_RESULT}  … +{len(lines) - max_lines} linhas{RESET}")
    print()


def print_sub(msg):
    print(f"  {GRAY}{SYM_RESULT}  {msg}{RESET}")


def print_response(text):
    if not text:
        return
    print()
    for line in text.split('\n'):
        if line.startswith('### '):
            print(f"  {BOLD}{LAVENDER}{line[4:]}{RESET}")
        elif line.startswith('## '):
            print(f"  {BOLD}{LAVENDER}{line[3:]}{RESET}")
        elif line.startswith('# '):
            print(f"  {BOLD}{LAVENDER}{line[2:]}{RESET}")
        elif line.startswith('```'):
            print(f"  {GRAY}{line}{RESET}")
        elif re.match(r'^\s*[-*] ', line):
            print(f"  {WHITE}{line}{RESET}")
        elif re.match(r'^\s*\d+\. ', line):
            print(f"  {WHITE}{line}{RESET}")
        else:
            print(f"  {WHITE}{line}{RESET}")
    print()



# ── Anexar arquivo a uma mensagem ─────────────────────────────────────────────
_CONTAINER_NAME_RE = re.compile(r'^[a-zA-Z0-9][a-zA-Z0-9_.-]*$')


def _is_container_path(fpath):
    """Detecta 'container:/abs/path'. Retorna (container, path) ou None."""
    if ':' not in fpath:
        return None
    # Windows path (C:\\... ou C:/...)
    if len(fpath) >= 3 and fpath[1] == ':' and fpath[2] in ('\\', '/'):
        return None
    # URL
    if '://' in fpath:
        return None
    container, _, path = fpath.partition(':')
    if not _CONTAINER_NAME_RE.match(container):
        return None
    if not path.startswith('/'):
        return None
    try:
        r = subprocess.run(
            ['docker', 'ps', '--format', '{{.Names}}',
             '--filter', f'name=^{re.escape(container)}$'],
            capture_output=True, text=True, timeout=3
        )
        names = [n for n in r.stdout.strip().split('\n') if n]
        if container not in names:
            return None
    except (subprocess.SubprocessError, FileNotFoundError, OSError):
        return None
    return (container, path)


def _read_remote_file(container, path, max_chars=20000):
    """Le arquivo de container Docker via 'docker exec cat'."""
    try:
        r = subprocess.run(
            ['docker', 'exec', container, 'cat', path],
            capture_output=True, timeout=10
        )
    except subprocess.TimeoutExpired:
        raise RuntimeError(f"timeout ao ler {container}:{path}")
    except FileNotFoundError:
        raise RuntimeError("docker nao encontrado no PATH")
    if r.returncode != 0:
        err = r.stderr.decode('utf-8', errors='replace').strip()
        raise RuntimeError(f"docker exec falhou: {err}")
    return r.stdout.decode('utf-8', errors='replace')[:max_chars]


def _attach_file(message, fpath, max_chars=20000):
    # Container path: 'container:/abs/path'
    remote = _is_container_path(fpath)
    if remote:
        container, path = remote
        content = _read_remote_file(container, path, max_chars)
        ext = Path(path).suffix[1:] or 'text'
        return f"```{ext}\n# {container}:{path}\n{content}\n```\n\n{message}"
    # Fallback local
    p = Path(fpath).expanduser()
    if not p.exists():
        raise FileNotFoundError(f"{fpath} nao encontrado")
    content = p.read_text(errors='replace')[:max_chars]
    ext = p.suffix[1:] or 'text'
    return f"```{ext}\n# {p}\n{content}\n```\n\n{message}"


# ── Chat (streaming SSE) ──────────────────────────────────────────────────────
async def chat(message, session_id=None, save_local=True):
    import httpx
    api_url = get_config('api_url', 'http://localhost:5002')
    api_key = get_config('api_key', '')

    if not api_key:
        print_error(
            f"API key nao configurada.\n"
            f"  Configure com: {BOLD}sirius config --key SUA_CHAVE{RESET}\n"
            f"  Obtenha sua chave em: {BLUE}siriusopen.ai{RESET}"
        )
        sys.exit(1)

    headers = {'X-API-Key': api_key, 'Content-Type': 'application/json'}
    payload = {
        'message':     message,
        'session_id':  session_id or '',
        'context_dir': str(Path.cwd()),
        'channel':     'cli',
    }

    tools_used = []
    credits_used = 0

    async with httpx.AsyncClient(timeout=300) as client:
        async with client.stream(
            'POST', f'{api_url}/api/cli/chat',
            json=payload, headers=headers
        ) as resp:
            if resp.status_code == 401:
                print_error("API key invalida.")
                sys.exit(1)
            if resp.status_code == 402:
                print_error("Creditos insuficientes. Recarregue em siriusopen.ai")
                sys.exit(1)
            if resp.status_code != 200:
                body = await resp.aread()
                print_error(f"Erro {resp.status_code}: {body.decode()}")
                sys.exit(1)

            result_text = ''
            new_session = session_id

            async for line in resp.aiter_lines():
                if not line.startswith('data: '):
                    continue
                try:
                    data = json.loads(line[6:])
                except json.JSONDecodeError:
                    continue

                event = data.get('event')

                if event == 'session':
                    new_session = data.get('session_id')

                elif event == 'tool_start':
                    spinner.stop()
                    name = data.get('name', '')
                    args = data.get('args', {})
                    display = TOOL_DISPLAY.get(name, name)
                    tools_used.append(name)
                    print_tool_call(name, args)
                    spinner.start(tool=display)

                elif event == 'tool_result':
                    spinner.stop()
                    result = data.get('result', '')
                    print_tool_result(str(result))

                elif event == 'thinking':
                    spinner.stop()
                    spinner.start()

                elif event == 'retry':
                    attempt = data.get('attempt', '')
                    wait    = data.get('wait', '')
                    spinner.update_sub(f"Retrying in {wait}s · attempt {attempt}/10")

                elif event == 'done':
                    result_text = data.get('text', '')
                    credits_used = int(data.get('credits_used', 1))
                    break

                elif event == 'error':
                    raise Exception(data.get('message', 'Erro desconhecido'))

    # Persistir sessao localmente
    if new_session and save_local:
        try:
            save_session_msg(new_session, 'user', message)
            save_session_msg(new_session, 'assistant', result_text, tools=tools_used)
        except Exception:
            pass

    return result_text, new_session, credits_used, tools_used



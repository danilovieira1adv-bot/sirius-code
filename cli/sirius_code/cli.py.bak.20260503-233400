# ── Spinner ───────────────────────────────────────────────────────────────────
class Spinner:
    def __init__(self):
        self._running  = False
        self._thread   = None
        self._word     = random.choice(SPINNER_WORDS)
        self._tool     = ''
        self._subtxt   = ''
        self._start_t  = 0

    def _spin(self):
        while self._running:
            elapsed = int(time.time() - self._start_t)
            if self._tool:
                line = (f'\r{ORANGE}{SYM_SPINNER}{RESET} '
                        f'{LAVENDER}{BOLD}{self._tool}{RESET} '
                        f'{GRAY}executando… ({elapsed}s){RESET}')
            else:
                line = (f'\r{LAVENDER}{SYM_SPINNER}{RESET} '
                        f'{WHITE}{self._word}…{RESET} '
                        f'{GRAY}({elapsed}s){RESET}')
            if self._subtxt:
                line += f'  {GRAY}{self._subtxt}{RESET}'
            sys.stdout.write(line)
            sys.stdout.flush()
            time.sleep(0.12)

    def start(self, tool='', subtxt=''):
        self._tool    = tool
        self._subtxt  = subtxt
        self._word    = random.choice(SPINNER_WORDS)
        self._start_t = time.time()
        if self._running:
            return
        self._running = True
        self._thread  = threading.Thread(target=self._spin, daemon=True)
        self._thread.start()

    def update_sub(self, subtxt):
        self._subtxt = subtxt

    def stop(self):
        self._running = False
        if self._thread:
            self._thread.join(timeout=0.3)
        sys.stdout.write('\r\033[K')
        sys.stdout.flush()



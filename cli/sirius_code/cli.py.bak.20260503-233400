def cmd_sessions():
    sessions = list_sessions(20)
    if not sessions:
        print(f"\n  {GRAY}Nenhuma sessao salva.{RESET}\n")
        return None
    print()
    print(f"  {BOLD}{WHITE}Sessoes recentes{RESET}")
    for i, s in enumerate(sessions, 1):
        sid = s['id'][:8]
        print(f"  {LAVENDER}{i:>2}.{RESET} {GRAY}{s.get('started',''):<19}{RESET} {LAVENDER}{sid}{RESET} {WHITE}{s['preview']}{RESET} {GRAY}({s['n']} msgs){RESET}")
    print()
    return sessions


def cmd_sessions_clear():
    if not SESSIONS_DIR.exists():
        print(f"\n  {GRAY}Nenhuma sessao para apagar.{RESET}\n")
        return
    files = list(SESSIONS_DIR.glob('*.json'))
    if not files:
        print(f"\n  {GRAY}Nenhuma sessao para apagar.{RESET}\n")
        return
    print(f"\n  {YELLOW}Apagar {len(files)} sessao(oes) salva(s)?{RESET}")
    try:
        c = input(f"  {LAVENDER}Confirmar (y/N): {RESET}").strip().lower()
    except (EOFError, KeyboardInterrupt):
        print()
        return
    if c not in ('y', 'yes', 's', 'sim'):
        print(f"  {GRAY}Cancelado.{RESET}\n")
        return
    n = 0
    for f in files:
        try:
            f.unlink()
            n += 1
        except Exception:
            pass
    print(f"  {GREEN}{SYM_OK} {n} sessao(oes) apagada(s).{RESET}\n")


def cmd_resume(arg):
    sessions = list_sessions(20)
    if not sessions:
        print(f"\n  {GRAY}Nenhuma sessao para retomar.{RESET}\n")
        return None
    target = None
    if arg:
        if arg.isdigit():
            idx = int(arg) - 1
            if 0 <= idx < len(sessions):
                target = sessions[idx]['id']
        else:
            for s in sessions:
                if s['id'].startswith(arg):
                    target = s['id']
                    break
    if not target:
        cmd_sessions()
        try:
            choice = input(f"{LAVENDER}Sessao (1-{len(sessions)}, Enter=cancelar): {RESET}").strip()
        except (EOFError, KeyboardInterrupt):
            print()
            return None
        if not choice:
            return None
        if choice.isdigit() and 1 <= int(choice) <= len(sessions):
            target = sessions[int(choice) - 1]['id']

    if not target:
        print(f"\n  {RED}Sessao invalida.{RESET}\n")
        return None

    data = load_session(target)
    if not data:
        print_error("Sessao nao encontrada.")
        return None
    print()
    print(f"  {GREEN}{SYM_OK} Retomando sessao {LAVENDER}{target[:8]}{RESET} ({len(data['messages'])} msgs)")
    for m in data['messages'][-4:]:
        role = m['role']
        c = m['content'][:200].replace('\n', ' ')
        if role == 'user':
            print(f"  {LAVENDER}{SYM_PROMPT}{RESET} {WHITE}{c}{RESET}")
        else:
            print(f"  {GRAY}{SYM_RESULT}{RESET}  {WHITE}{c}{RESET}")
    print()
    return target



"""Sirius Code CLI — visual espelhado ao Claude Code v2.1.121"""
import sys, os, json, asyncio, threading, time, shutil, re, random
import re
import subprocess
from pathlib import Path

CONFIG_DIR   = Path.home() / ".sirius"
CONFIG_FILE  = CONFIG_DIR / "config.json"
SESSIONS_DIR = CONFIG_DIR / "sessions"

def load_config():
    if CONFIG_FILE.exists():
        return json.loads(CONFIG_FILE.read_text())
    return {}

def save_config(cfg):
    CONFIG_DIR.mkdir(exist_ok=True)
    CONFIG_FILE.write_text(json.dumps(cfg, indent=2))

def get_config(key, default=None):
    return load_config().get(key, default)

# ── Sessions persistentes ─────────────────────────────────────────────────────
def _session_path(sid):
    return SESSIONS_DIR / f"{sid}.json"

def save_session_msg(sid, role, content, tools=None):
    if not sid:
        return
    SESSIONS_DIR.mkdir(parents=True, exist_ok=True)
    p = _session_path(sid)
    if p.exists():
        try:
            data = json.loads(p.read_text())
        except Exception:
            data = {"id": sid, "started": time.strftime("%Y-%m-%d %H:%M:%S"), "messages": []}
    else:
        data = {"id": sid, "started": time.strftime("%Y-%m-%d %H:%M:%S"), "messages": []}
    msg = {"role": role, "content": content, "ts": time.strftime("%H:%M:%S")}
    if tools:
        msg["tools"] = tools
    data["messages"].append(msg)
    p.write_text(json.dumps(data, indent=2, ensure_ascii=False))

def list_sessions(limit=20):
    if not SESSIONS_DIR.exists():
        return []
    files = sorted(SESSIONS_DIR.glob("*.json"), key=lambda p: p.stat().st_mtime, reverse=True)
    out = []
    for f in files[:limit]:
        try:
            d = json.loads(f.read_text())
            msgs = d.get("messages", [])
            preview = msgs[0]["content"][:60] if msgs else "(vazio)"
            out.append({
                "id": d.get("id", f.stem),
                "started": d.get("started", ""),
                "preview": preview,
                "n": len(msgs),
            })
        except Exception:
            pass
    return out

def load_session(sid):
    p = _session_path(sid)
    if p.exists():
        try:
            return json.loads(p.read_text())
        except Exception:
            return None
    return None


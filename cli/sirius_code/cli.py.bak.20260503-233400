def cmd_config(args):
    cfg = load_config()
    if '--key' in args:
        idx = args.index('--key')
        cfg['api_key'] = args[idx + 1]
        save_config(cfg)
        print_ok("API key configurada.")
    elif '--url' in args:
        idx = args.index('--url')
        cfg['api_url'] = args[idx + 1]
        save_config(cfg)
        print_ok(f"URL configurada: {args[idx + 1]}")
    elif '--show' in args:
        key = cfg.get('api_key', 'nao configurada')
        url = cfg.get('api_url', 'http://localhost:5002')
        masked = key[:8] + '...' + key[-4:] if len(key) > 12 else key
        print(f"\n  API Key : {LAVENDER}{masked}{RESET}")
        print(f"  API URL : {BLUE}{url}{RESET}\n")
    else:
        print("\n  Uso: sirius config --key CHAVE | --url URL | --show\n")


def cmd_repl():
    print_header()
    print(_sep())
    print(f"  {GRAY}Digite sua tarefa. {LAVENDER}/help{GRAY} para comandos. Ctrl+C para sair.{RESET}")
    print(_sep())
    print()

    session_id = None

    while True:
        try:
            user_input = input(f"{LAVENDER}{SYM_PROMPT}{RESET} ").strip()
        except (EOFError, KeyboardInterrupt):
            print(f"\n{GRAY}Ate logo.{RESET}\n")
            break

        if not user_input:
            continue

        if user_input in ('/exit', '/quit'):
            print(f"\n{GRAY}Ate logo.{RESET}\n")
            break

        if user_input == '/help':
            print()
            print(f"  {BOLD}{WHITE}Comandos:{RESET}")
            cmds = [
                ('/exit',                  'Sair'),
                ('/clear',                 'Limpar tela'),
                ('/new',                   'Nova sessao (limpa contexto)'),
                ('/session',               'Ver sessao atual'),
                ('/sessions',              'Listar sessoes salvas'),
                ('/resume [n|id]',         'Retomar sessao anterior'),
                ('/cost',                  'Ver creditos e metricas'),
                ('/file <path> <prompt>',  'Anexar arquivo na proxima mensagem'),
                ('/btw <texto>',           'Pergunta rapida sem perder contexto'),
            ]
            for cmd, desc in cmds:
                print(f"  {LAVENDER}{cmd:<24}{RESET} {GRAY}{desc}{RESET}")
            print()
            continue

        if user_input == '/clear':
            os.system('clear')
            print_header()
            print(_sep())
            print()
            continue

        if user_input in ('/session', '/context'):
            sid = session_id or 'nova'
            print(f"\n  {GRAY}Sessao: {LAVENDER}{sid}{RESET}\n")
            continue

        if user_input == '/new':
            session_id = None
            print(f"\n  {GREEN}{SYM_OK} Nova sessao iniciada.{RESET}\n")
            continue

        if user_input.startswith('/sessions'):
            arg = user_input[len('/sessions'):].strip()
            if arg == 'clear':
                cmd_sessions_clear()
            else:
                cmd_sessions()
            continue

        if user_input.startswith('/resume'):
            arg = user_input[len('/resume'):].strip()
            new_sid = cmd_resume(arg)
            if new_sid:
                session_id = new_sid
            continue

        if user_input == '/cost':
            cmd_cost()
            continue

        if user_input.startswith('/file '):
            rest = user_input[len('/file '):].strip()
            parts = rest.split(' ', 1)
            if len(parts) < 2:
                print_error("Uso: /file <caminho> <pergunta>")
                continue
            try:
                user_input = _attach_file(parts[1], parts[0])
            except Exception as e:
                print_error(f"Erro ao ler arquivo: {e}")
                continue

        if user_input.startswith('/btw '):
            user_input = f"[BTW] {user_input[5:]}"

        # Processa tarefa
        print(_sep())
        spinner.start()

        try:
            result, session_id, credits, tools = asyncio.run(chat(user_input, session_id))
            spinner.stop()
            print_response(result)
            if credits and credits > 0:
                tinfo = f" {GRAY}{SYM_DOT} {len(tools)} tools{RESET}" if tools else ''
                print(f"  {GRAY}{credits} creditos consumidos{tinfo}{RESET}")
        except KeyboardInterrupt:
            spinner.stop()
            print(f"\n  {ORANGE}{SYM_DIAMOND} Interrompido.{RESET}\n")
        except Exception as e:
            spinner.stop()
            print_error(str(e))

        print(_sep())
        print()


# ── Entry point ──────────────────────────────────────────────────────────────
def main():
    args = sys.argv[1:]

    if not args:
        cmd_repl()
        return

    cmd = args[0]

    if cmd == 'config':
        cmd_config(args[1:])
        return

    if cmd in ('version', '--version', '-v'):
        print(f"{LAVENDER}{SYM_DIAMOND} Sirius Code v1.0.0{RESET}")
        return

    if cmd in ('status', '--status'):
        import httpx
        async def check():
            api_url = get_config('api_url', 'http://localhost:5002')
            api_key = get_config('api_key', '')
            async with httpx.AsyncClient(timeout=10) as c:
                r = await c.get(f'{api_url}/status', headers={'X-API-Key': api_key})
                return r.json()
        try:
            asyncio.run(check())
            print_ok("Sirius Code online")
        except Exception as e:
            print_error(f"Offline: {e}")
        return

    if cmd in ('cost', '--cost', 'usage'):
        cmd_cost()
        return

    if cmd in ('sessions', '--sessions'):
        cmd_sessions()
        return

    # Headless: sirius "task" ou sirius --file foo.py "explique"
    file_arg = None
    if '--file' in args:
        idx = args.index('--file')
        if idx + 1 < len(args):
            file_arg = args[idx + 1]
            args = args[:idx] + args[idx + 2:]

    message = ' '.join(args)

    if file_arg:
        try:
            message = _attach_file(message, file_arg)
        except Exception as e:
            print_error(f"Erro ao ler {file_arg}: {e}")
            sys.exit(1)

    spinner.start()
    try:
        result, _, credits, tools = asyncio.run(chat(message))
        spinner.stop()
        print_response(result)
        if credits and credits > 0:
            tinfo = f" {GRAY}{SYM_DOT} {len(tools)} tools{RESET}" if tools else ''
            print(f"  {GRAY}{credits} creditos consumidos{tinfo}{RESET}")
    except Exception as e:
        spinner.stop()
        print_error(str(e))
        sys.exit(1)


if __name__ == '__main__':
    main()
